   "source": [
    "# 입력한 횟수대로 반복하기\n",
    "\n",
    "count = int(input(\"반복할 횟수를 입력하세요: \"))\n",
    "\n",
    "i=0\n",
    "\n",
    "while True:\n",
    "    print(i)\n",
    "\n",
    "    i += 1\n",
    "\n",
    "    if i == count:\n",
    "        break\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
