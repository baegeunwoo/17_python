   "metadata": {},
   "outputs": [],
   "source": [
    "i=1\n",
    "stop=20\n",
    "while True:\n",
    "    if i%10 != 3:\n",
    "        continue\n",
    "    if i==stop:\n",
    "        break\n",
    "    print(i, end=' ')\n",
    "    i += 1"
   ]
